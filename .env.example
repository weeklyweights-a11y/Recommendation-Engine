# Database
DATABASE_URL=postgresql+asyncpg://personalmatch:personalmatch@localhost:5432/personalmatch
ALEMBIC_DATABASE_URL=postgresql+psycopg2://personalmatch:personalmatch@localhost:5432/personalmatch
REDIS_URL=redis://localhost:6379/0

# Docker Postgres (must match DATABASE_URL database name)
POSTGRES_DB=personalmatch
POSTGRES_USER=personalmatch
POSTGRES_PASSWORD=personalmatch

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_AUTH=neo4j/change_me

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=jobs

# LLM — Google Gemini (Phase 2+)
# Pro: resume extraction (Step 2.2), match explanations (Step 4.3)
# Flash: batch job field extraction (Step 3.1), high-volume LLM calls
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_AI_API_KEY=your_google_api_key_here
LLM_MODEL_PRO=gemini-2.5-pro
LLM_MODEL_FLASH=gemini-2.5-flash
LLM_MAX_TOKENS=4096

# GitHub (Phase 2)
GITHUB_TOKEN=your_github_token_here

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss_indexes/
ESCO_EMBEDDINGS_PATH=./data/esco/skill_embeddings.npy
ESCO_URI_INDEX_PATH=./data/esco/skill_uri_index.json

# Paths
ESCO_DATA_PATH=./data/esco/
SCRAPER_CONFIG_PATH=./config/scraper_config.yaml
SCRAPER_OUTPUT_PATH=./data/sample_jobs/scraped_jobs.jsonl
SCRAPER_DEFAULT_MODE=both
KAGGLE_JOBS_PATH=./data/sample_jobs/

# Skill graph
SKILL_EXPANSION_MAX_HOPS=3
SKILL_HOP_DECAY_1=1.0
SKILL_HOP_DECAY_2=0.5
SKILL_HOP_DECAY_3=0.25
SKILL_BROADER_PENALTY=0.8
FUZZY_MATCH_THRESHOLD=0.85
SEMANTIC_MATCH_THRESHOLD=0.75
SKILL_CACHE_SIZE=10000

# Ingestion (Phase 2)
RESUME_MAX_FILE_BYTES=10485760
RESUME_MIN_TEXT_CHARS=50
RESUME_MAX_TEXT_CHARS=100000
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_MAX_REPOS=300
GITHUB_TOP_REPOS_LANGUAGES=20
GITHUB_TOP_REPOS_README=10
GITHUB_TOP_REPOS_SIGNALS=20
GITHUB_RATE_LIMIT_WARN_THRESHOLD=10
GITHUB_RATE_LIMIT_MAX_RETRIES=3
GITHUB_FORK_RECENCY_DAYS=180
GITHUB_LLM_SUMMARY_MAX_CHARS=4000
GITHUB_USERNAME_MAX_LENGTH=39
SKILL_DEPTH_RESUME_MENTION=0.25
SKILL_DEPTH_RESUME_PROFICIENCY=0.15
SKILL_DEPTH_GITHUB_PRESENCE=0.25
SKILL_DEPTH_GITHUB_RECENCY=0.15
SKILL_DEPTH_GITHUB_PRODUCTION=0.10
SKILL_DEPTH_GITHUB_VOLUME=0.10
SKILL_DEPTH_BASE_RESUME_ONLY=0.3
SKILL_DEPTH_BASE_GITHUB_ONLY=0.2
SKILL_EXPANSION_MAX_HOPS_EMBED=1
EMBEDDING_DEVICE=auto
EMBEDDING_CHUNK_TOKEN_LIMIT=512

# Retrieval
BM25_TOP_K=500
HYBRID_TOP_K=500
ES_INDEX_BATCH_SIZE=500
KAGGLE_BATCH_SIZE=1000
VECTOR_SKILL_WEIGHT=0.35
VECTOR_DOMAIN_WEIGHT=0.25
VECTOR_ROLE_WEIGHT=0.25
VECTOR_ENVIRONMENT_WEIGHT=0.15
VECTOR_OVERFETCH_MULTIPLIER=2
VECTOR_ZERO_NORM_EPSILON=0.000001
GRAPH_EXPANSION_MAX_HOPS=2
GRAPH_DIRECT_MATCH_WEIGHT=1.0
GRAPH_ONE_HOP_WEIGHT=0.5
GRAPH_TWO_HOP_WEIGHT=0.25
FUSION_BM25_WEIGHT=0.25
FUSION_VECTOR_WEIGHT=0.45
FUSION_GRAPH_WEIGHT=0.30
FUSION_STRATEGY=rrf
RRF_K=60
RETRIEVAL_ES_TERMS_FILTER_MAX=5000

# Job embedding (Phase 3)
JOB_EMBED_BATCH_SIZE=64
JOB_LLM_BATCH_SIZE=10
JOB_SKILL_DICT_PATH=./data/esco/supplemental_aliases.csv
FAISS_FLAT_IP_MAX_JOBS=50000
FAISS_INDEX_TYPE=
FAISS_IVF_NLIST=0
FAISS_NPROBE=10

# Reranker (Phase 4) — defaults shown; override to tune utility function
RERANK_SKILL_FIT_WEIGHT=0.25
RERANK_EXPERIENCE_ALIGNMENT_WEIGHT=0.15
RERANK_DOMAIN_RELEVANCE_WEIGHT=0.15
RERANK_ROLE_SHAPE_WEIGHT=0.15
RERANK_LOCATION_FIT_WEIGHT=0.10
RERANK_COMPANY_STAGE_WEIGHT=0.10
RERANK_SEMANTIC_WEIGHT=0.10
DOMAIN_SIMILARITY_PATH=./config/domain_similarity.yaml
ROLE_COMPATIBILITY_PATH=./config/role_compatibility.yaml

# Explainer (Phase 4)
EXPLAIN_TOP_K=20
EXPLAIN_BATCH_SIZE=5
EXPLAIN_LOG_TOKEN_USAGE=true

# Hard filters (Phase 4)
HARD_FILTER_MIN_RESULTS_WARN=50
HARD_FILTER_PIPELINE_MIN_WARN=10
HARD_FILTER_ALL_WORK_MODELS=remote,hybrid,onsite

# Recommendations cache (Phase 4)
RECOMMENDATION_CACHE_TTL_SECONDS=3600
RECOMMENDATION_RERANK_TOP_K=50
RECOMMENDATION_STORE_TOP_K=50
RECOMMENDATION_EXPLAIN_TOP_K=20

# API (Phase 4)
CORS_ORIGINS=http://localhost:8501
API_RATE_LIMIT=100/minute
API_DEFAULT_PAGE=1
API_DEFAULT_PER_PAGE=20
API_MAX_PER_PAGE=100
API_PREFERENCE_TEXT_MAX_LENGTH=500

# App
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501
LOG_LEVEL=INFO
