# Database
DATABASE_URL=postgresql+asyncpg://personalmatch:personalmatch@localhost:5432/personalmatch
ALEMBIC_DATABASE_URL=postgresql+psycopg2://personalmatch:personalmatch@localhost:5432/personalmatch
REDIS_URL=redis://localhost:6379/0

# Docker Postgres (must match DATABASE_URL database name)
POSTGRES_DB=personalmatch
POSTGRES_USER=personalmatch
POSTGRES_PASSWORD=personalmatch

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_AUTH=neo4j/change_me

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=jobs

# LLM (Phase 2)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# GitHub (Phase 2)
GITHUB_TOKEN=your_github_token_here

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss_indexes/
ESCO_EMBEDDINGS_PATH=./data/esco/skill_embeddings.npy
ESCO_URI_INDEX_PATH=./data/esco/skill_uri_index.json

# Paths
ESCO_DATA_PATH=./data/esco/
SCRAPER_CONFIG_PATH=./config/scraper_config.yaml
SCRAPER_OUTPUT_PATH=./data/sample_jobs/scraped_jobs.jsonl
SCRAPER_DEFAULT_MODE=both
KAGGLE_JOBS_PATH=./data/sample_jobs/

# Skill graph
SKILL_EXPANSION_MAX_HOPS=3
SKILL_HOP_DECAY_1=1.0
SKILL_HOP_DECAY_2=0.5
SKILL_HOP_DECAY_3=0.25
SKILL_BROADER_PENALTY=0.8
FUZZY_MATCH_THRESHOLD=0.85
SEMANTIC_MATCH_THRESHOLD=0.75
SKILL_CACHE_SIZE=10000

# Retrieval
BM25_TOP_K=500
ES_INDEX_BATCH_SIZE=500
KAGGLE_BATCH_SIZE=1000

# App
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501
LOG_LEVEL=INFO
